############################################
# STATIC ASSET SUBDOMAIN SECURITY HARDENING
############################################

# --------------------------------------------------
# 1) Prevent directory listing
# --------------------------------------------------
Options -Indexes -ExecCGI

# --------------------------------------------------
# 2) Allow localhost + private networks
# --------------------------------------------------
<RequireAny>
    Require local
    Require ip 10.0.0.0/8
    Require ip 172.16.0.0/12
    Require ip 192.168.0.0/16
    Require ip 84.65.145.55
</RequireAny>

# --------------------------------------------------
# 3) Force HTTPS (enable once SSL works)
# --------------------------------------------------
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# --------------------------------------------------
# 4) HSTS (enable AFTER HTTPS confirmed)
# --------------------------------------------------
#<IfModule mod_headers.c>
#Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
#</IfModule>

# --------------------------------------------------
# 5) Cache Control for Static Assets
# --------------------------------------------------
<IfModule mod_headers.c>
Header set Cache-Control "public, max-age=31536000, immutable"
</IfModule>

# --------------------------------------------------
# 6) Security Headers
# --------------------------------------------------
<IfModule mod_headers.c>

Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set X-XSS-Protection "1; mode=block"

</IfModule>

# --------------------------------------------------
# 7) Disable ALL server-side script execution
# --------------------------------------------------
<FilesMatch "\.(php|php5|phtml|phps|cgi|pl|py|jsp|asp|aspx)$">
Require all denied
</FilesMatch>

RemoveHandler .php .php5 .phtml .phps .cgi .pl .py .jsp .asp .aspx

# --------------------------------------------------
# 8) CORS – allow only approved websites
# --------------------------------------------------
<IfModule mod_headers.c>

SetEnvIf Origin "https?://([a-z0-9-]+\.)?(webtechfocus\.com)$" CORS_ALLOWED_ORIGIN=$0
SetEnvIf Origin "https?://([a-z0-9-]+\.)?(marlenematos\.com)$" CORS_ALLOWED_ORIGIN=$0

Header always set Access-Control-Allow-Origin "%{CORS_ALLOWED_ORIGIN}e" env=CORS_ALLOWED_ORIGIN
Header always set Access-Control-Allow-Methods "GET,HEAD,OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type"

</IfModule>

# --------------------------------------------------
# 8a) Fonts MUST allow CORS
# --------------------------------------------------
<FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
<IfModule mod_headers.c>
Header always set Access-Control-Allow-Origin "*"
</IfModule>
</FilesMatch>

# --------------------------------------------------
# 9) Aggressive caching
# --------------------------------------------------
<IfModule mod_expires.c>

ExpiresActive On

# Images
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"

# CSS / JS
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType text/javascript "access plus 1 month"

# Fonts
ExpiresByType application/font-woff2 "access plus 1 year"

</IfModule>

# --------------------------------------------------
# 10) Hotlink protection (images only)
# --------------------------------------------------
<IfModule mod_rewrite.c>

RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?webtechfocus\.com/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?marlenematos\.com/ [NC]

# Allowed Social Networks
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?twitter\.com/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?x\.com/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?linkedin\.com/ [NC]
RewriteCond %{HTTP_REFERER} !^https?://([a-z0-9-]+\.)?facebook\.com/ [NC]

RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,NC,L]

</IfModule>

# --------------------------------------------------
# 11) Prevent MIME sniffing for assets
# --------------------------------------------------
<IfModule mod_headers.c>
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|woff|woff2)$">
Header always set X-Content-Type-Options "nosniff"
</FilesMatch>
</IfModule>